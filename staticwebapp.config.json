{
  "routes": [
    {
      "route": "/*",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/.auth/login/aad",
      "allowedRoles": ["unauthenticated"]
    },
    {
      "route": "/.auth/login/github",
      "allowedRoles": ["unauthenticated"]
    },
    {
      "route": "/.auth/logout",
      "allowedRoles": ["unauthenticated"]
    }
  ],
  "responseOverrides": {
    "401": {
      "redirect": "/.auth/login/aad",
      "statusCode": 302
    }
  }
}
